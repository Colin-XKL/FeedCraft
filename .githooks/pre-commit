#!/bin/sh
set -eu

echo "Running pre-commit checks..."
# ACMR: Added, Copied, Modified, Renamed
staged_files=$(git diff --cached --name-only --diff-filter=ACMR | tr '\n' ' ')

if [ -n "$staged_files" ]; then
  echo "Formatting staged files..."
  task format FILES="$staged_files"
  
  # Re-add formatted files to ensure they are included in the commit
  for file in $staged_files; do
    if [ -f "$file" ]; then
      git add "$file"
    fi
  done
fi

